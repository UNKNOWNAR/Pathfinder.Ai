# ============================================================
# Pathfinder.Ai — Environment Variables
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit secrets.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
SECURITY_PASSWORD_SALT=change-me-to-another-random-string
ENVIRONMENT=development

# ── Database (Neon.tech Free PostgreSQL) ─────────────────────
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxx.neon.tech/neondb?sslmode=require

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── AI / LLM (Groq — Free) ───────────────────────────────────
# Sign up at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Embeddings (Jina AI — 1M tokens/month free) ──────────────
# Sign up at: https://jina.ai
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Job Harvesting APIs ───────────────────────────────────────
# RapidAPI key (used for LinkedIn/JSearch, Internships, Google Jobs)
# Sign up at: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna (2000 free calls/month)
# Sign up at: https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── File Storage (Supabase — 1GB free) ───────────────────────
# Sign up at: https://supabase.com
# 1. Create a project
# 2. Create 'avatars' (public) and 'resumes' (private) buckets
# 3. Get your URL and SERVICE_ROLE_KEY from Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
