# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Flask
FLASK_DEBUG=False
SECRET_KEY=change-me
SECURITY_PASSWORD_SALT=change-me

# PostgreSQL (AWS RDS / local Postgres)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/pathfinder

# JWT
JWT_SECRET_KEY=change-me

# HuggingFace
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adzuna API (https://developer.adzuna.com/ — free tier available)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# JSearch via RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=your_rapidapi_key_here
